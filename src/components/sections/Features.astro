---
import { Icon } from "astro-icon/components";

interface Feature {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features = [] } = Astro.props;
---

<section class="bg-white rounded-lg">
  <div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    {
      (title || subtitle) && (
        <div class="text-center max-w-3xl mx-auto mb-16">
          {title && (
            <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">
              {title}
            </h2>
          )}
          {subtitle && <p class="text-xl text-gray-600" set:html={subtitle} />}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        features.map((feature) => {
          const Component = feature.link ? 'a' : 'div';
          return (
            <Component
              href={feature.link}
              class="p-6 rounded-lg border border-gray-200 hover:border-primary-light hover:shadow-lg transition group"
            >
              {feature.icon && (
                <div class="w-12 h-12 bg-neutral rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary-dark transition">
                  <Icon name={feature.icon} class="w-6 h-6 text-primary-dark group-hover:text-white transition" />
                </div>
              )}
              <h3 class="text-xl font-semibold text-primary-dark mb-2">
                {feature.title}
              </h3>
              <p class="text-gray-600" set:html={feature.description} />
              {feature.link && (
                <span class="inline-flex items-center text-primary font-medium mt-3 group-hover:gap-2 transition-all">
                  Learn more
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              )}
            </Component>
          );
        })
      }
    </div>
  </div>
</section>
