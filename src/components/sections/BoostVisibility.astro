---
import { Icon } from "astro-icon/components";

interface Feature {
  title?: string;
  description?: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ctaText?: string;
  ctaLink?: string;
  features: Feature[];
}

const {
  title,
  description,
  image,
  ctaText,
  ctaLink,
  features = [],
} = Astro.props;
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      {
        title && (
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">
            {title}
          </h2>
        )
      }
      {description && <p class="text-xl text-gray-600" set:html={description} />}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      {
        image && (
          <div class="relative overflow-hidden rounded-lg shadow-lg">
            {image.includes('ucarecdn.com') ? (
              <picture>
                <source
                  media="(max-width: 640px)"
                  srcset={image.replace(/\/-\/preview\/\d+x\d+\//, '/-/preview/640x480/-/format/webp/')}
                  type="image/webp"
                />
                <source
                  srcset={image.replace(/\/-\/preview\/\d+x\d+\//, '/-/preview/665x499/-/format/webp/')}
                  type="image/webp"
                />
                <img
                  src={image}
                  alt={title || "Digital Marketing Solutions"}
                  width="665"
                  height="499"
                  class="w-full h-auto object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            ) : (
              <img
                src={image}
                alt={title || "Digital Marketing Solutions"}
                width="665"
                height="499"
                class="w-full h-auto object-cover"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        )
      }

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {
          features.map((feature) => {
            const Component = feature.link ? 'a' : 'div';
            return (
              <Component
                href={feature.link}
                class="p-6 bg-white rounded-lg border border-gray-200 hover:border-primary hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group cursor-pointer"
              >
                {feature.icon && (
                  <div class="w-12 h-12 bg-neutral rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary group-hover:scale-110 transition-all duration-300">
                    <Icon name={feature.icon} class="w-6 h-6 text-primary group-hover:text-white transition-colors duration-300" />
                  </div>
                )}
                <h3 class="text-lg font-semibold text-primary-dark mb-2 group-hover:text-primary transition-colors duration-300">
                  {feature.title}
                </h3>
                <p class="text-gray-600 text-sm">{feature.description}</p>
                {feature.link && (
                  <span class="inline-flex items-center text-primary font-medium text-sm mt-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    Learn more
                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                )}
              </Component>
            );
          })
        }
      </div>
    </div>

    {
      ctaText && ctaLink && (
        <div class="text-center mt-12">
          <a
            href={ctaLink}
            class="inline-flex items-center justify-center px-8 py-4 bg-primary-dark text-white font-medium rounded-lg hover:bg-black transition"
          >
            {ctaText}
          </a>
        </div>
      )
    }
  </div>
</section>
