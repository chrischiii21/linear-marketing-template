---
import { Icon } from "astro-icon/components";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  cards: Card[];
}

const { title, description, ctaText, ctaLink, cards = [] } = Astro.props;
---

<section class="py-12 md:py-24 bg-primary-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      (title || description) && (
        <div class="text-center max-w-3xl mx-auto mb-8 md:mb-12">
          {title && (
            <h2 class="text-2xl md:text-4xl font-bold mb-3 md:mb-4">{title}</h2>
          )}
          {description && (
            <p class="text-base md:text-xl text-neutral mb-6 md:mb-8" set:html={description} />
          )}
          {ctaText && ctaLink && (
            <a
              href={ctaLink}
              class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-dark font-medium rounded-lg hover:bg-neutral transition"
            >
              {ctaText}
            </a>
          )}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {
        cards.map((card) => (
          <a
            href={card.link || "#"}
            class="p-6 bg-neutral rounded-lg hover:bg-white transition group"
          >
            {card.icon && (
              <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center mb-4 group-hover:bg-neutral-dark transition">
                <Icon name={card.icon} class="w-6 h-6 text-primary-dark" />
              </div>
            )}
            <h3 class="text-xl font-semibold mb-2 text-primary-dark">{card.title}</h3>
            <p class="text-gray-700">{card.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
