---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  keyPoints?: string[];
  relatedLinks?: Array<{
    text: string;
    href: string;
  }>;
}

const { title, description, ctaText, ctaLink, keyPoints = [], relatedLinks = [] } = Astro.props;
---

<section class="py-16 md:py-24 bg-gradient-to-b from-neutral to-white relative overflow-hidden">
  <!-- Subtle decorative element -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary-light/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-12">
      {
        title && (
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-primary-dark mb-6 leading-tight">
            {title}
          </h2>
        )
      }
      {
        description && (
          <p class="text-lg md:text-xl text-gray-700 leading-relaxed" set:html={description} />
        )
      }
    </div>

    {
      keyPoints.length > 0 && (
        <div class="max-w-4xl mx-auto mb-12">
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {keyPoints.map((point) => (
              <li class="flex items-start bg-white/60 backdrop-blur-sm p-4 rounded-lg shadow-sm hover:shadow-md transition">
                <svg
                  class="w-6 h-6 text-primary-dark mr-3 flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                <span class="text-base text-gray-800 font-medium">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      ctaText && ctaLink && (
        <div class="text-center">
          <a
            href={ctaLink}
            class="inline-flex items-center justify-center px-8 py-4 bg-primary-dark text-white font-semibold rounded-lg hover:bg-black transform hover:scale-105 transition-all shadow-lg hover:shadow-xl text-base"
          >
            {ctaText}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      )
    }

    {
      relatedLinks && relatedLinks.length > 0 && (
        <div class="text-center mt-12 pt-8 border-t border-gray-300/50">
          <p class="text-gray-600 text-sm font-medium mb-4">You might also be interested in:</p>
          <div class="flex flex-wrap gap-4 justify-center">
            {relatedLinks.map((link) => (
              <a
                href={link.href}
                class="text-primary-dark hover:text-black transition-colors underline decoration-2 underline-offset-4 text-sm font-semibold hover:decoration-primary"
              >
                {link.text}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
