---
import { CTA_BACKGROUND_IMAGE } from "~/lib/config";

interface Props {
  title?: string;
  subtitle?: string;
  backgroundImage?: string;
  actions?: Array<{
    text: string;
    href: string;
    variant?: "primary" | "secondary";
  }>;
  relatedLinks?: Array<{
    text: string;
    href: string;
  }>;
}

const {
  title = "Ready to get started?",
  subtitle = "Contact us today to learn how we can help grow your business.",
  backgroundImage = CTA_BACKGROUND_IMAGE,
  actions = [{ text: "Get in Touch", href: "/contact-us", variant: "primary" }],
  relatedLinks = [],
} = Astro.props;
---

<section class="py-16 md:py-24 bg-primary-dark relative">
  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${backgroundImage}');`}
  ></div>
  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-black/70"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      {title}
    </h2>
    <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto" set:html={subtitle} />

    {
      actions.length > 0 && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {actions.map((action) => (
            <a
              href={action.href}
              class={
                action.variant === "secondary"
                  ? "px-8 py-3 text-base font-medium rounded-lg border-2 border-white text-white hover:bg-white hover:text-primary-dark transition"
                  : "px-8 py-3 text-base font-medium rounded-lg bg-white text-primary-dark hover:bg-neutral transition"
              }
            >
              {action.text}
            </a>
          ))}
        </div>
      )
    }

    {
      relatedLinks && relatedLinks.length > 0 && (
        <div class="mt-8 pt-8 border-t border-white/20">
          <p class="text-neutral text-sm mb-4">Explore more:</p>
          <div class="flex flex-wrap gap-4 justify-center">
            {relatedLinks.map((link) => (
              <a
                href={link.href}
                class="text-white hover:text-neutral transition underline text-sm"
              >
                {link.text}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
