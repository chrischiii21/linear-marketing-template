---
import { POPUP_CONFIG, siteConfig } from "~/config/site";

interface Props {
  title?: string;
  ctaText?: string;
  ctaLink?: string;
  delay?: number;
  showOnce?: boolean;
}

const {
  title = "Get Your Free Marketing Consultation",
  ctaText = "Schedule Free Consultation",
  ctaLink = "/contact-us",
  delay = 5000,
  showOnce = true,
} = Astro.props;

const {
  image: popupImage,
  badge: popupBadge,
  headline: popupHeadline,
  description: popupDescription,
  benefits: popupBenefits,
  trustIndicators,
  dismissText,
  floatingButtonText,
} = POPUP_CONFIG;
---

<div
  id="popup-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  data-delay={delay}
  data-show-once={showOnce}
>
  <!-- Modal Container -->
  <div
    class="relative w-full max-w-4xl mx-4 bg-white rounded-2xl shadow-2xl overflow-hidden animate-scale-in"
  >
    <!-- Close Button -->
    <button
      id="close-popup"
      class="absolute top-4 right-4 z-20 w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-lg hover:bg-gray-50 transition-colors"
      aria-label="Close popup"
    >
      <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Two Column Layout -->
    <div class="flex flex-col md:flex-row">
      <!-- Left Side - Image -->
      <div class="md:w-2/5 relative bg-primary-dark hidden md:block">
        <img
          src={popupImage}
          alt="Marketing consultation"
          width="400"
          height="600"
          class="w-full h-64 md:h-full object-cover opacity-80"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-primary-dark/60 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/90 backdrop-blur-sm rounded-lg mb-4">
            <span class="w-2 h-2 bg-primary-dark rounded-full animate-pulse"></span>
            <span class="text-xs font-bold text-primary-dark uppercase tracking-wider">{popupBadge}</span>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-white leading-tight">
            {title}
          </h3>
        </div>
      </div>

      <!-- Right Side - Content -->
      <div class="w-full md:w-3/5 px-8 md:px-10 py-10 md:py-12 flex flex-col justify-center space-y-6">
        <!-- Logo -->
        <div class="flex justify-center mb-4 md:mb-6 pl-16 md:pl-24">
          <img
            src={siteConfig.logo.src}
            alt={siteConfig.logo.alt}
            width="220"
            height="58"
            class="h-16 md:h-20 w-auto"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Headline -->
        <div class="space-y-3 text-center">
          <h4 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight">
            {popupHeadline}
          </h4>
          <p class="text-base md:text-lg text-gray-600 leading-relaxed">
            {popupDescription}
          </p>
        </div>

        <!-- Benefits List -->
        <ul class="space-y-3">
          {popupBenefits.map((benefit) => (
            <li class="flex items-center gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-lg bg-neutral flex items-center justify-center">
                <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <span class="text-sm md:text-base text-gray-700 font-medium">{benefit}</span>
            </li>
          ))}
        </ul>

        <!-- CTA Button -->
        <a
          href={ctaLink}
          class="block w-full px-6 md:px-8 py-4 md:py-5 bg-primary-dark text-white text-center font-bold text-base md:text-lg rounded-lg hover:bg-primary-lighter transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-[1.02]"
        >
          {ctaText}
        </a>

        <!-- Trust Indicators -->
        <div class="flex flex-wrap items-center justify-center gap-x-4 md:gap-x-5 gap-y-2 text-xs md:text-sm text-gray-600 pt-1">
          {trustIndicators.map((indicator) => (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 md:w-5 md:h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span class="font-semibold">{indicator}</span>
            </div>
          ))}
        </div>

        <!-- Secondary Action -->
        <button
          id="close-popup-bottom"
          class="block w-full text-sm md:text-base text-gray-500 hover:text-primary transition-colors text-center underline underline-offset-2"
        >
          {dismissText}
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Floating CTA Button - Icon only on mobile -->
<button
  id="floating-cta-btn"
  class="fixed bottom-6 right-6 z-40 md:px-6 md:py-3 p-4 bg-primary-dark text-white font-bold text-sm rounded-lg shadow-2xl hover:bg-primary-lighter hover:scale-105 transition-all duration-300 flex items-center gap-2 group"
  aria-label={floatingButtonText}
>
  <svg class="w-5 h-5 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
  </svg>
  <span class="hidden md:inline">{floatingButtonText}</span>
</button>

<script>
  function closePopup() {
    const popup = document.getElementById('popup-modal');
    if (!popup) return;

    popup.style.display = 'none';
    document.body.style.overflow = '';
  }

  function showPopup() {
    const popup = document.getElementById('popup-modal');
    if (!popup) return;

    // Don't show popup on mobile devices
    if (window.innerWidth < 768) return;

    const showOnce = popup.getAttribute('data-show-once') === 'true';
    const storageKey = 'popup-shown';

    if (showOnce && sessionStorage.getItem(storageKey)) return;

    popup.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    if (showOnce) {
      sessionStorage.setItem(storageKey, 'true');
    }
  }

  function initPopup() {
    const popup = document.getElementById('popup-modal');
    if (!popup) return;

    const closeBtn = document.getElementById('close-popup');
    const closeBottomBtn = document.getElementById('close-popup-bottom');
    const floatingBtn = document.getElementById('floating-cta-btn');

    if (closeBtn) {
      closeBtn.addEventListener('click', closePopup);
    }

    if (closeBottomBtn) {
      closeBottomBtn.addEventListener('click', closePopup);
    }

    if (floatingBtn) {
      floatingBtn.addEventListener('click', function (e) {
        e.preventDefault();
        const popup = document.getElementById('popup-modal');
        if (!popup) return;

        popup.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    }

    // Close on backdrop click
    popup.addEventListener('click', function (e) {
      if (e.target === popup) {
        closePopup();
      }
    });

    // Auto-show logic
    const showOnce = popup.getAttribute('data-show-once') === 'true';
    if (showOnce && sessionStorage.getItem('popup-shown')) return;

    let scrollTriggered = false;
    function handleScroll() {
      if (!scrollTriggered && window.scrollY > 50) {
        scrollTriggered = true;
        showPopup();
        window.removeEventListener('scroll', handleScroll);
      }
    }
    window.addEventListener('scroll', handleScroll);

    setTimeout(function () {
      if (!scrollTriggered) {
        showPopup();
        window.removeEventListener('scroll', handleScroll);
      }
    }, 2000);
  }

  // Escape key handler, added once, works across all navigations
  document.addEventListener('keydown', function (e) {
    const popup = document.getElementById('popup-modal');
    if (e.key === 'Escape' && popup && popup.style.display === 'flex') {
      closePopup();
    }
  });

  // Re-initialize on every navigation (including initial load)
  // This is required for Astro View Transitions (ClientRouter) compatibility
  document.addEventListener('astro:page-load', initPopup);
</script>

<style>
  @keyframes scale-in {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-scale-in {
    animation: scale-in 0.3s ease-out;
  }
</style>
