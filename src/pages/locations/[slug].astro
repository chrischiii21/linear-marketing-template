---
import { getCollection, type CollectionEntry } from "astro:content";
import PageLayout from "~/layouts/PageLayout.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import Hero from "~/components/sections/Hero.astro";
import FAQs from "~/components/sections/FAQs.astro";
import ContentWithImage from "~/components/sections/ContentWithImage.astro";
import CTALight from "~/components/sections/CTALight.astro";
import FeaturesSection from "~/components/sections/FeaturesSection.astro";
import FeaturesWithImage from "~/components/sections/FeaturesWithImage.astro";
import Map from "~/components/sections/MapSection.astro";
import { getPageTitle, localizeData, SITE_URL } from "~/lib/config";
import { locationBusinessSchema, faqSchema } from "~/lib/schema";

export async function getStaticPaths() {
  const locations = await getCollection("locations");
  return locations.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"locations">;
};

const { entry } = Astro.props;
const data = localizeData(entry.data);

const sections = (data.sections || []).sort(
  (a: any, b: any) => (a.order || 0) - (b.order || 0)
);

const metadata = {
  title: getPageTitle(data.metadata?.title || data.title),
  description: data.metadata?.description || data.description,
  keywords: data.metadata?.keywords,
};

const pageUrl = `${SITE_URL}/locations/${entry.id}`;
const faqs = sections.find((s: any) => s.section === "FAQs" && s.faqs)?.faqs;

const pageSchemas = [
  locationBusinessSchema({
    url: pageUrl,
    city: data.location,
    description: data.description,
  }),
  faqs ? faqSchema(faqs) : null,
].filter(Boolean);

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Locations", url: "/locations" },
  { name: data.location, url: `/locations/${entry.id}` },
];
---

<PageLayout metadata={metadata} schemas={pageSchemas} breadcrumbs={breadcrumbs}>
  {
    sections.map((section: any) => {
      // Hero Section
      if (section.section === "Hero") {
        return (
          <Hero
            tagline={section.eyebrow}
            title={section.title}
            subtitle={section.description}
            image={section.image}
            actions={
              section.ctaText && section.ctaLink
                ? [
                    {
                      text: section.ctaText,
                      href: section.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      // Benefits Section (render as FeaturesSection)
      if (section.section === "Benefits" && section.benefits) {
        return (
          <FeaturesSection
            title={section.title}
            description={section.description}
            features={section.benefits}
          />
        );
      }

      // FAQs Section
      if (section.section === "FAQs" && section.faqs) {
        return (
          <FAQs
            title={section.title}
            faqs={section.faqs}
          />
        );
      }

      // ContentWithImage Section
      if (section.section === "ContentWithImage") {
        return (
          <ContentWithImage
            title={section.title}
            eyebrow={section.eyebrow}
            description={section.description}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            image={section.image}
            imagePosition={section.imagePosition}
            background={section.background}
          />
        );
      }

      // CTALight Section
      if (section.section === "CTALight") {
        return (
          <CTALight
            title={section.title}
            description={section.description}
            ctaText={section.ctaText || "Get in Touch"}
            ctaLink={section.ctaLink || "/contact-us"}
          />
        );
      }

      // Features Sections
      if (
        section.section === "FeaturesWithImage" ||
        section.section === "FeaturesSection"
      ) {
        if (!section.features) return null;
        
        if (section.section === "FeaturesWithImage") {
          return (
            <FeaturesWithImage
              eyebrow={section.eyebrow}
              title={section.title}
              description={section.description}
              cards={section.features}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
            />
          );
        }
        
        return (
          <FeaturesSection
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            features={section.features}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
          />
        );
      }

      // Map Section
      if (section.section === "Map") {
        const filteredLocations = (section.locations || []).filter(
          (loc: any) => (loc.name || loc) !== data.location
        );
        return (
          <Map
            title={section.title}
            description={section.description}
            mapUrl={section.mapUrl}
            locations={filteredLocations}
            viewMode={section.viewMode}
          />
        );
      }

      return null;
    })
  }

  <CallToAction
    title="Ready to Get Started?"
    subtitle="Contact us today to discuss your project and see how we can help your business grow."
    actions={[
      {
        text: "Get in Touch",
        href: "/contact-us",
        variant: "primary",
      },
    ]}
  />
</PageLayout>
