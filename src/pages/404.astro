---
import BaseLayout from "~/layouts/BaseLayout.astro";

const metadata = {
  title: "404 - Page Not Found",
  description: "The page you're looking for doesn't exist.",
  noindex: true,
  nofollow: true,
};
---

<BaseLayout metadata={metadata}>
  <style is:global>
    /* Hide footer on 404 page */
    body footer {
      display: none;
    }
  </style>
  <!-- 404 Hero Section -->
  <section class="relative bg-primary-dark text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40 text-center">
      <!-- 404 Number -->
      <div class="mb-8">
        <h1 class="text-[120px] sm:text-[180px] lg:text-[240px] font-bold leading-none tracking-tight opacity-20">
          404
        </h1>
      </div>

      <!-- Content -->
      <div class="relative -mt-32 sm:-mt-40 lg:-mt-48">
        <p class="text-primary-light text-lg sm:text-xl mb-4 font-medium">
          Oops! Page Not Found
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">
          We Can't Find That Page
        </h2>
        <p class="text-gray-300 text-lg sm:text-xl max-w-2xl mx-auto mb-12">
          The page you're looking for might have been moved, deleted, or never existed in the first place.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary-dark bg-white rounded-lg hover:bg-neutral transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            Back to Home
          </a>
          <a
            href="/contact-us"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-transparent border-2 border-white rounded-lg hover:bg-white hover:text-primary-dark transition-all duration-300 hover:-translate-y-1"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Helpful Links Section -->
  <section class="bg-neutral py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h3 class="text-2xl sm:text-3xl font-bold text-primary-dark mb-4">
          Looking for Something Else?
        </h3>
        <p class="text-gray-600 text-lg">
          Here are some helpful links to get you back on track
        </p>
      </div>

      <!-- Quick Links Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Link Card 1 -->
        <a
          href="/indoor-billboards/screen-advertising"
          class="group bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-neutral-dark"
        >
          <div class="w-12 h-12 bg-primary-dark rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary transition-colors">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-bold text-primary-dark mb-2">Screen Advertising</h4>
          <p class="text-gray-600 text-sm">Learn about our digital billboard solutions</p>
        </a>

        <!-- Link Card 2 -->
        <a
          href="/indoor-billboards/locations"
          class="group bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-neutral-dark"
        >
          <div class="w-12 h-12 bg-primary-dark rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary transition-colors">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-bold text-primary-dark mb-2">Our Locations</h4>
          <p class="text-gray-600 text-sm">Find screens near you</p>
        </a>

        <!-- Link Card 3 -->
        <a
          href="/indoor-billboards/become-a-venue-partner"
          class="group bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-neutral-dark"
        >
          <div class="w-12 h-12 bg-primary-dark rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary transition-colors">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-bold text-primary-dark mb-2">Become a Partner</h4>
          <p class="text-gray-600 text-sm">Join our venue network</p>
        </a>

        <!-- Link Card 4 -->
        <a
          href="/contact-us"
          class="group bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-neutral-dark"
        >
          <div class="w-12 h-12 bg-primary-dark rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary transition-colors">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-bold text-primary-dark mb-2">Contact Us</h4>
          <p class="text-gray-600 text-sm">Get in touch with our team</p>
        </a>
      </div>
    </div>
  </section>


</BaseLayout>
